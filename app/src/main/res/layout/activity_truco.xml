<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FD"
    tools:context=".TrucoActivity">

    <!-- BLOCO 1: PONTUAÇÃO MÁXIMA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="PONTUAÇÃO MÁXIMA"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:text="12 pts"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- BLOCO 2: PLACAR AZUL GRANDE -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#004694">

        <!-- Divisor horizontal para separar Equipe 1 e Equipe 2 lado a lado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Lado Esquerdo: Equipe 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EQUIPE 1"
                    android:textColor="#A0C4FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Linha sutil separando as duas equipes -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#20FFFFFF" />

            <!-- Lado Direito: Equipe 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EQUIPE 2"
                    android:textColor="#A0C4FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- BLOCO 3: BOTÕES DA EQUIPE 1 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="+ pontos para Equipe 1"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- Botão +1 -->
        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="+1"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <!-- Botão +3 -->
        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="+3"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <!-- Botão +6 -->
        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="+6"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <!-- Botão +9 -->
        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="+9"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <!-- Botão +12 -->
        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="+12"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <!-- BLOCO 4: BOTÕES DA EQUIPE 2 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="+ pontos para Equipe 2"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="+1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="+3"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="+6"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="+9"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="+12"
            android:textSize="12sp"
            android:textColor="#1D2A44"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <!-- BLOCO 5: HISTÓRICO DE JOGADAS -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Histórico de jogadas"
        android:textColor="#1D2A44"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Nenhuma jogada ainda."
        android:textColor="#888888"
        android:textSize="14sp"
        android:textStyle="italic" />

</LinearLayout>