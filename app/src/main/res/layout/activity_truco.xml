<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="32dp"
    android:paddingRight="32dp"
    android:background="#F8F9FD"
    android:orientation="vertical"
    android:paddingTop="64dp"
    tools:context=".TrucoActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/pontua_o_maxima_maiuscula"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/doze_pts"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/truco"
        android:textColor="#000000"
        android:textSize="32sp"
        android:textStyle="bold" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:cardBackgroundColor="#004694"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nome_equipe_dois"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A0C4FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/placar_pontos_equipe_um"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_inicial"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#20FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nome_equipe_um"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A0C4FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/placar_pontos_equipe_dois"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_inicial"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/nome_equipe_um_pontos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/add_pontos_para_equipe_1"
        android:textStyle="bold"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            style="?android:attr/absListViewStyle"
            android:id="@+id/add_um_pontos_equipe_um"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:maxLines="1"
            android:padding="0dp"
            android:layout_weight="1"
            android:text="@string/add_1_equipe_1"
            android:onClick="addPontosEquipeUm"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:id="@+id/add_tres_pontos_equipe_um"
            android:layout_height="54dp"
            android:maxLines="1"
            android:onClick="addPontosEquipeUm"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/add_3_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:id="@+id/add_seis_pontos_equipe_um"
            android:layout_marginEnd="4dp"
            android:maxLines="1"
            android:onClick="addPontosEquipeUm"
            android:padding="0dp"
            android:layout_weight="1"
            android:text="@string/add_6_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:id="@+id/add_nove_pontos_equipe_um"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:onClick="addPontosEquipeUm"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_9_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:id="@+id/add_doze_pontos_equipe_um"
            android:maxLines="1"
            android:padding="0dp"
            android:onClick="addPontosEquipeUm"
            android:text="@string/add_12_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/nome_equipe_dois_pontos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/add_pontos_para_equipe_2"
        android:textStyle="bold"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:id="@+id/add_um_pontos_equipe_dois"
            android:layout_weight="1"
            android:maxLines="1"
            android:onClick="addPontosEquipeDois"
            android:padding="0dp"
            android:text="@string/add_1_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:id="@+id/add_tres_pontos_equipe_dois"
            android:maxLines="1"
            android:padding="0dp"
            android:onClick="addPontosEquipeDois"
            android:text="@string/add_3_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:id="@+id/add_seis_pontos_equipe_dois"
            android:maxLines="1"
            android:padding="0dp"
            android:onClick="addPontosEquipeDois"
            android:text="@string/add_6_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:id="@+id/add_nove_pontos_equipe_dois"
            android:maxLines="1"
            android:padding="0dp"
            android:onClick="addPontosEquipeDois"
            android:text="@string/add_9_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:id="@+id/add_doze_pontos_equipe_dois"
            android:text="@string/add_12_equipe_2"
            android:textColor="#1D2A44"
            android:onClick="addPontosEquipeDois"
            android:maxLines="1"
            android:padding="0dp"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:contentDescription="@string/reverter_ultima_pontuacao"
            android:onClick="reverterUltimaPontuacao"
            android:layout_height="54dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#FFF9C4"
            android:layout_weight="1"
            app:icon="@drawable/outline_keyboard_return_24"
            app:iconTint="#666666"
            app:iconGravity="textStart"
            android:textColor="#666666"
            android:textSize="20sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="24dp"
            app:strokeColor="#E0E0E0"
            app:iconPadding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:contentDescription="@string/reiniciar_a_partida"
            android:onClick="reiniciarPartida"
            android:layout_height="54dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            app:icon="@drawable/outline_restart_alt_24"
            app:iconTint="#666666"
            app:iconGravity="textStart"
            android:backgroundTint="#FFE0B2"
            android:textColor="#666666"
            android:textSize="18sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="24dp"
            app:strokeColor="#E0E0E0"
            app:iconPadding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:contentDescription="@string/finalizar_a_partida"
            android:onClick="finalizarPartida"
            app:iconGravity="textStart"
            android:layout_weight="1.2"
            app:icon="@drawable/outline_flag_24"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="#E51C23"
            app:iconPadding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="24dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/historico_de_jogadas"
        android:textColor="#1D2A44"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/historico_resultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/nenhuma_jogada_ainda"
        android:textColor="#888888"
        android:textSize="14sp"
        android:textStyle="italic" />

</LinearLayout>