<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="32dp"
    android:background="#F8F9FD"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".TrucoActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/pontua_o_maxima_maiuscula"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/doze_pts"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/truco"
        android:textColor="#000000"
        android:textSize="32sp"
        android:textStyle="bold" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#004694"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/equipe_1"
                    android:textColor="#A0C4FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_inicial"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#20FFFFFF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/equipe_2"
                    android:textColor="#A0C4FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/valor_inicial"
                    android:textColor="#FFFFFF"
                    android:textSize="70sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/add_pontos_para_equipe_1"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:maxLines="1"
            android:padding="0dp"
            android:layout_weight="1"
            android:text="@string/add_1_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:maxLines="1"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/add_3_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:maxLines="1"
            android:padding="0dp"
            android:layout_weight="1"
            android:text="@string/add_6_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_9_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_12_equipe_1"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/add_pontos_para_equipe_2"
        android:textColor="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_1_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_3_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_6_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:padding="0dp"
            android:text="@string/add_9_equipe_2"
            android:textColor="#1D2A44"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />

        <Button
            style="?android:attr/absListViewStyle"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="@string/add_12_equipe_2"
            android:textColor="#1D2A44"
            android:maxLines="1"
            android:padding="0dp"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F8"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/historico_de_jogadas"
        android:textColor="#1D2A44"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/nenhuma_jogada_ainda"
        android:textColor="#888888"
        android:textSize="14sp"
        android:textStyle="italic" />

</LinearLayout>